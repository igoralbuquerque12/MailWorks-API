# App
PORT=3000
NODE_ENV=development

# PostgreSQL — usada pelo Prisma
DATABASE_URL="postgresql://mailworks:mailworks@localhost:5432/mailworks"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# API Key padrão para 2FA e desenvolvimento (gerada pelo seed: npx prisma db seed)
DEFAULT_API_KEY=dev-api-key-insecure

# SMTP para o seed (opcional — pode configurar diretamente no banco depois)
SMTP_HOST=smtp.gmail.com
SMTP_USER=SEU_EMAIL@gmail.com
SMTP_PASS=SUA_APP_PASSWORD
